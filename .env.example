# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=finance
DB_PASSWORD=finance_secret
DB_NAME=finance_tracker
DB_SSLMODE=disable
DATABASE_URL=postgres://finance:finance_secret@localhost:5432/finance_tracker?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Ollama
OLLAMA_URL=http://localhost:11434

# Gmail (OAuth2)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_POLL_INTERVAL=15m
GMAIL_QUERY=from:(alerts@pnc.com OR no.reply.alerts@chase.com OR alert@chase.com)

# Server
SERVER_PORT=8080

# Default admin user (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
