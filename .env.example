# ──────────────────────────────────────────────
# Finance Tracker — Environment Configuration
# Copy this file:  cp .env.example .env
# Then fill in the values below.
# ──────────────────────────────────────────────

# Database (defaults work out of the box with docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=finance
DB_PASSWORD=finance_secret
DB_NAME=finance_tracker
DB_SSLMODE=disable
DATABASE_URL=postgres://finance:finance_secret@localhost:5432/finance_tracker?sslmode=disable

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=

# Ollama (runs on host, accessed from Docker via host.docker.internal)
OLLAMA_URL=http://localhost:11434

# Gmail OAuth (optional — needed for email-based transaction import)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_POLL_INTERVAL=15m
GMAIL_QUERY=from:(pncalerts@visa.com OR no.reply.alerts@chase.com OR pncalerts@pnc.com)

# Server
SERVER_PORT=8080

# Default admin user (seeded on first run — change the password!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ngrok tunnel — sign up at https://ngrok.com (free)
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
# Claim a free static domain from: https://dashboard.ngrok.com/domains
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Your Vercel frontend URL (set after deploying, without trailing slash)
# Example: finance-tracker-abc123.vercel.app
VERCEL_URL=
